# ---- 複製成 .env 並填入自己的值（.env 不會進版控） ----

# 儀表板埠號
PORT=3030

# 抓取設定
CRAWL_RELDATE_DAYS=30     # 回溯天數：抓最近 N 天發表的論文
CRAWL_RETMAX=50           # 每個主題每次最多抓幾篇

# NCBI（皆非必填）：填 email 讓 NCBI 可在異常時聯繫；有 API key 可提高速率上限
NCBI_EMAIL=coeusxd@gmail.com
NCBI_API_KEY=

# ---- Email 摘要（兩種擇一；都不填就自動略過寄信）----

# 收件人（你的信箱）
MAIL_TO=coeusxd@gmail.com

# 方式一（推薦，雲端友善）：Resend HTTP API — 不需 Gmail 密碼，只要一把 API key
#   1. 到 resend.com 用 coeusxd@gmail.com 註冊（免費方案每天 100 封）
#   2. 建一把 API key 貼到下面
#   3. 未驗證自有網域時，寄件人固定用 onboarding@resend.dev，收件人須為註冊信箱
RESEND_API_KEY=
MAIL_FROM=hair-papers <onboarding@resend.dev>

# 方式二（備援）：SMTP，例如 Gmail 應用程式密碼（16 碼，非登入密碼）
# 設了 RESEND_API_KEY 時會優先用 Resend，這區可留空
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
