# ---- 複製成 .env 並填入自己的值（.env 不會進版控） ----

# 儀表板埠號
PORT=3030

# 抓取設定
CRAWL_RELDATE_DAYS=30     # 回溯天數：抓最近 N 天發表的論文
CRAWL_RETMAX=50           # 每個主題每次最多抓幾篇

# NCBI（皆非必填）：填 email 讓 NCBI 可在異常時聯繫；有 API key 可提高速率上限
NCBI_EMAIL=coeusxd@gmail.com
NCBI_API_KEY=

# ---- Email 摘要（不填就自動略過寄信）----
# Gmail 範例：需先到 Google 帳號開啟兩步驟驗證，再產生「應用程式密碼」填在 SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=coeusxd@gmail.com
SMTP_PASS=              # 這裡填 Gmail 應用程式密碼（16 碼），不是你的登入密碼
MAIL_FROM=coeusxd@gmail.com
MAIL_TO=coeusxd@gmail.com
